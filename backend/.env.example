# Server Configuration
PORT=8000
ENVIRONMENT=development

# Database Configuration (Required)
# Local: postgresql://username:password@localhost:5432/dbname
# Railway/Heroku provides this automatically
DATABASE_URL=postgresql://postgres:YourPassword@localhost:5432/patient_registration

# Vapi Configuration (Required for voice AI)
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PHONE_NUMBER_ID=your_phone_number_id_here
VAPI_WEBHOOK_SECRET=your_webhook_secret_here

# OpenAI Configuration (Optional - Vapi can use its own)
OPENAI_API_KEY=sk-proj-your_openai_key_here

# CORS Configuration (JSON array format)
# Local: ["*"] allows all origins
# Production: ["https://yourdomain.com"]
CORS_ORIGINS=["*"]

# Logging
LOG_LEVEL=INFO

